{
  "name": "coderef",
  "displayName": "coderef",
  "description": "Resolve, click-open, and verify regex-defined references in source code",
  "keywords": [
    "coderef",
    "regex",
    "references",
    "todo",
    "documentation"
  ],
  "version": "0.2.2",
  "publisher": "helly25",
  "license": "Apache-2.0",
  "icon": "images/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/helly25/coderef.git",
    "directory": "extension"
  },
  "homepage": "https://github.com/helly25/coderef",
  "bugs": "https://github.com/helly25/coderef/issues",
  "engines": {
    "vscode": "^1.92.0"
  },
  "categories": ["Linters", "Other"],
  "activationEvents": [
    "workspaceContains:.coderef.jsonc",
    "workspaceContains:.coderef.json",
    "workspaceContains:.config/coderef.jsonc",
    "workspaceContains:.config/coderef.json"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "coderef",
      "properties": {
        "coderef.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Master switch for the coderef extension."
        },
        "coderef.configPath": {
          "type": "string",
          "default": "",
          "description": "Optional explicit path to the .coderef.jsonc, relative to the workspace root. Empty = auto-detect."
        },
        "coderef.references.maxNodesPerLevel": {
          "type": "number",
          "default": 1000,
          "minimum": 10,
          "description": "Cap on the number of nodes shown at any level of the references browser tree (per-category file list, per-file leaf list). Levels exceeding the cap are truncated with a placeholder; the doctor's references.tooManyNodes diagnostic surfaces the same condition. Lower values keep the tree responsive on huge repos."
        },
        "coderef.references.scanMode": {
          "type": "string",
          "default": "workspace",
          "enum": ["workspace", "openFiles", "currentFile"],
          "enumDescriptions": [
            "Scan every in-scope file in the workspace (default).",
            "Scan only files currently open as TextDocuments in the host.",
            "Scan only the active editor's file."
          ],
          "description": "Determines which files the references browser scans on refresh. `workspace` honours .gitignore + the config `ignore[]`. `openFiles` / `currentFile` are fast modes for very large workspaces."
        }
      }
    },
    "commands": [
      {
        "command": "coderef.explainReference",
        "title": "coderef: Explain reference at cursor",
        "category": "coderef"
      },
      {
        "command": "coderef.references.refresh",
        "title": "coderef: Refresh references browser",
        "category": "coderef",
        "icon": "$(refresh)"
      },
      {
        "command": "coderef.references.copyAsMarkdown",
        "title": "coderef: Copy references as Markdown",
        "category": "coderef",
        "icon": "$(clippy)"
      },
      {
        "command": "coderef.references.exportJson",
        "title": "coderef: Export references as JSON",
        "category": "coderef",
        "icon": "$(save-as)"
      },
      {
        "command": "coderef.references.setScanMode",
        "title": "coderef: Set references scan mode (workspace / openFiles / currentFile)",
        "category": "coderef"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "coderef.explainReference",
          "group": "navigation@1",
          "when": "editorTextFocus"
        }
      ],
      "view/title": [
        {
          "command": "coderef.references.copyAsMarkdown",
          "when": "view == coderef.references",
          "group": "navigation@1"
        },
        {
          "command": "coderef.references.exportJson",
          "when": "view == coderef.references",
          "group": "navigation@2"
        },
        {
          "command": "coderef.references.refresh",
          "when": "view == coderef.references",
          "group": "navigation@3"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "coderef",
          "title": "coderef",
          "icon": "$(link)"
        }
      ]
    },
    "views": {
      "coderef": [
        {
          "id": "coderef.references",
          "name": "References",
          "contextualTitle": "coderef references browser"
        }
      ]
    }
  },
  "scripts": {
    "compile":       "tsc -p ./",
    "compile-test":  "tsc -p ./tsconfig.test.json",
    "watch":         "tsc -watch -p ./",
    "lint":          "eslint src",
    "test":          "node --test --import tsx 'src/*.test.ts'",
    "test-runtime":  "npm run build && npm run compile-test && vscode-test",
    "bundle-wasm":   "node ./scripts/bundle-wasm.cjs",
    "build":         "npm run compile && npm run bundle-wasm",
    "vscode:prepublish": "npm run build",
    "package":       "npm run build && vsce package",
    "publish":       "npm run build && vsce publish"
  },
  "devDependencies": {
    "@eslint/js":               "^9.39.4",
    "@types/mocha":             "^10.0.10",
    "@types/node":              "^22.19.19",
    "@types/vscode":            "^1.92.0",
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "@typescript-eslint/parser":        "^8.60.0",
    "@vscode/test-cli":         "^0.0.10",
    "@vscode/test-electron":    "^2.5.2",
    "@vscode/vsce":             "^3.9.1",
    "eslint":                   "^9.39.4",
    "globals":                  "^15.15.0",
    "mocha":                    "^11.7.4",
    "tsx":                      "^4.20.6",
    "typescript":               "^5.9.3",
    "typescript-eslint":        "^8.60.0"
  }
}
