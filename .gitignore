coverage/

# Coderef runtime / cache
.coderef-cache/
.coderef/

# npm wrapper: postinstall drops the platform binary here.
# bin/coderef.js is the launcher and is tracked; bin/coderef[.exe] is
# the installed artifact and is not.
npm/coderef/bin/coderef
npm/coderef/bin/coderef.exe

# OS
.DS_Store
Thumbs.db

# Editors
.idea/
*.swp

